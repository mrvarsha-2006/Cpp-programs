#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    int countRangeSum(vector<int>& nums, int lower, int upper) {
        int n = nums.size();
        // Use long long to avoid overflow during prefix sum calculation
        vector<long long> prefix_sums(n + 1, 0);
        for (int i = 0; i < n; ++i) {
            prefix_sums[i + 1] = prefix_sums[i] + nums[i];
        }
        return mergeSort(prefix_sums, 0, n + 1, lower, upper);
    }

private:
    int mergeSort(vector<long long>& sums, int start, int end, int lower, int upper) {
        if (end - start <= 1) return 0;
        
        int mid = start + (end - start) / 2;
        int count = mergeSort(sums, start, mid, lower, upper) + 
                    mergeSort(sums, mid, end, lower, upper);
        
        int j_start = mid, j_end = mid, t = mid;
        vector<long long> cache(end - start);
        int r = 0;
        
        for (int i = start; i < mid; ++i) {
            // Find the window [j_start, j_end) in the right half where prefix_sums[j] - prefix_sums[i] is in [lower, upper]
            while (j_start < end && sums[j_start] - sums[i] < lower) j_start++;
            while (j_end < end && sums[j_end] - sums[i] <= upper) j_end++;
            
            // Standard merge logic: while sorting, count the valid ranges found above
            while (t < end && sums[t] < sums[i]) cache[r++] = sums[t++];
            cache[r++] = sums[i];
            
            count += (j_end - j_start);
        }
        
        // Copy the remaining elements from the right half into the cache
        copy(cache.begin(), cache.begin() + r, sums.begin() + start);
        return count;
    }
};

#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    void generate(int open, int close, int n, string current, vector<string> &result) {
        // If valid combination is formed
        if (current.length() == 2 * n) {
            result.push_back(current);
            return;
        }

        // Add '(' if possible
        if (open < n) {
            generate(open + 1, close, n, current + '(', result);
        }

        // Add ')' only if valid
        if (close < open) {
            generate(open, close + 1, n, current + ')', result);
        }
    }

    vector<string> generateParenthesis(int n) {
        vector<string> result;
        generate(0, 0, n, "", result);
        return result;
    }
};

int main() {
    Solution obj;
    vector<string> ans = obj.generateParenthesis(3);

    for (string s : ans) {
        cout << s << endl;
    }

    return 0;
}

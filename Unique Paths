#include <vector>

class Solution {
public:
    int uniquePaths(int m, int n) {
        // Use a 1D vector to store the number of ways to reach each column
        // Initialize with 1 because there's only 1 way to reach any cell in the first row
        std::vector<int> row(n, 1);
        
        // Start from the second row (index 1)
        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {
                // The new value is the current value (from above) 
                // plus the value to the left (already updated in this loop)
                row[j] += row[j - 1];
            }
        }
        
        return row[n - 1];
    }
};

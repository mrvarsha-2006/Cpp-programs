#include <string>
#include <vector>

class Solution {
public:
    std::string getPermutation(int n, int k) {
        std::vector<int> numbers;
        std::vector<int> factorial(n, 1);
        
        // 1. Prepare factorials and number list
        for (int i = 1; i < n; i++) {
            factorial[i] = factorial[i - 1] * i;
            numbers.push_back(i);
        }
        numbers.push_back(n); // numbers = {1, 2, ..., n}

        k--; // Convert to 0-based index
        std::string result = "";

        // 2. Build the permutation digit by digit
        for (int i = n - 1; i >= 0; i--) {
            int index = k / factorial[i];
            k %= factorial[i];
            
            result += std::to_string(numbers[index]);
            numbers.erase(numbers.begin() + index); // Remove used digit
        }

        return result;
    }
};

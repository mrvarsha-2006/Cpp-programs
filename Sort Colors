#include <vector>
#include <algorithm>

class Solution {
public:
    void sortColors(std::vector<int>& nums) {
        int low = 0;
        int mid = 0;
        int high = nums.size() - 1;

        while (mid <= high) {
            if (nums[mid] == 0) {
                // If it's a 0, swap it to the front (low)
                std::swap(nums[low], nums[mid]);
                low++;
                mid++;
            } 
            else if (nums[mid] == 1) {
                // If it's a 1, it's already in the "middle"
                mid++;
            } 
            else { // nums[mid] == 2
                // If it's a 2, swap it to the end (high)
                std::swap(nums[mid], nums[high]);
                // Don't increment mid here because the swapped 
                // element from high hasn't been processed yet.
                high--;
            }
        }
    }
};

#include <vector>
#include <numeric>
#include <algorithm>

class Solution {
public:
    int candy(std::vector<int>& ratings) {
        int n = ratings.size();
        if (n <= 1) return n;

        // Every child starts with at least 1 candy
        std::vector<int> candies(n, 1);

        // 1. Left-to-Right Pass
        // If the current child has a higher rating than the left, give them more
        for (int i = 1; i < n; i++) {
            if (ratings[i] > ratings[i - 1]) {
                candies[i] = candies[i - 1] + 1;
            }
        }

        // 2. Right-to-Left Pass
        // If the current child has a higher rating than the right, check if
        // their current count is already sufficient; if not, update it.
        for (int i = n - 2; i >= 0; i--) {
            if (ratings[i] > ratings[i + 1]) {
                candies[i] = std::max(candies[i], candies[i + 1] + 1);
            }
        }

        // 3. Sum up the results
        return std::accumulate(candies.begin(), candies.end(), 0);
    }
};

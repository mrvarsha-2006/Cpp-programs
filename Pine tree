#include<iostream>
using namespace std;
void find(int x, int y2)
{
    int c=4,f=2,t=3,s=5;
    for (int y=x;y<=y2;y++)
    {
        if((y-x)%c==0&&(y-x)%f==0&&(y-x)%t==0&&(y-x)%s==0)
        {
            cout<<"All positions change in year "<<y<<endl;
        }
    }
}
int main()
{
    try
    {
        int y_x,y_y;
        std::cin>>y_x;
        std::cin>>y_y;
        find(y_x,y_y);
    }
    catch(exception &e)
    {
        
    }
}

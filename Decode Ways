#include <string>
#include <vector>

class Solution {
public:
    int numDecodings(std::string s) {
        if (s.empty() || s[0] == '0') return 0;

        int n = s.length();
        int prev2 = 1; // Ways to decode string of length i-2
        int prev1 = 1; // Ways to decode string of length i-1

        for (int i = 2; i <= n; i++) {
            int current = 0;
            int singleDigit = s[i - 1] - '0';
            int doubleDigit = std::stoi(s.substr(i - 2, 2));

            // Case 1: Can we decode the current digit as a single character?
            if (singleDigit >= 1) {
                current += prev1;
            }

            // Case 2: Can we decode the last two digits as a single character?
            if (doubleDigit >= 10 && doubleDigit <= 26) {
                current += prev2;
            }

            prev2 = prev1;
            prev1 = current;

            // If no ways found for this position, the whole string is invalid
            if (prev1 == 0) return 0;
        }

        return prev1;
    }
};

#include <string>

class Solution {
public:
    bool isMatch(std::string s, std::string p) {
        int sIdx = 0, pIdx = 0, lastWildcard = -1, sNext = -1;
        
        while (sIdx < s.length()) {
            // Case 1: Characters match or pattern has '?'
            if (pIdx < p.length() && (p[pIdx] == '?' || p[pIdx] == s[sIdx])) {
                sIdx++;
                pIdx++;
            } 
            // Case 2: Pattern has '*'
            else if (pIdx < p.length() && p[pIdx] == '*') {
                lastWildcard = pIdx; // Remember wildcard position
                sNext = sIdx;        // Mark current s index to backtrack to
                pIdx++;              // Try matching * with empty sequence first
            } 
            // Case 3: No match, but we saw a '*' earlier
            else if (lastWildcard != -1) {
                pIdx = lastWildcard + 1; // Backtrack to after the *
                sNext++;                 // Match one more character of s with that *
                sIdx = sNext;
            } 
            // Case 4: No match and no previous '*'
            else {
                return false;
            }
        }
        
        // Handle trailing '*' in pattern
        while (pIdx < p.length() && p[pIdx] == '*') {
            pIdx++;
        }
        
        return pIdx == p.length();
    }
};

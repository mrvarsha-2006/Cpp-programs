#include <vector>
#include <algorithm>

class Solution {
public:
    void moveZeroes(std::vector<int>& nums) {
        // 'lastNonZeroFoundAt' points to the position where 
        // the next non-zero element should be moved.
        for (int lastNonZeroFoundAt = 0, cur = 0; cur < nums.size(); cur++) {
            if (nums[cur] != 0) {
                std::swap(nums[lastNonZeroFoundAt++], nums[cur]);
            }
        }
    }
};

#include <vector>
#include <string>
#include <algorithm>

class Solution {
public:
    int minCut(std::string s) {
        int n = s.length();
        if (n <= 1) return 0;

        // isPal[i][j] will be true if s[i...j] is a palindrome
        std::vector<std::vector<bool>> isPal(n, std::vector<bool>(n, false));
        std::vector<int> dp(n);

        for (int i = 0; i < n; i++) {
            int minCuts = i; // Maximum possible cuts
            for (int j = 0; j <= i; j++) {
                // Check if s[j...i] is a palindrome
                if (s[i] == s[j] && (i - j <= 2 || isPal[j + 1][i - 1])) {
                    isPal[j][i] = true;
                    
                    // If s[0...i] is a palindrome, 0 cuts needed
                    if (j == 0) {
                        minCuts = 0;
                    } else {
                        minCuts = std::min(minCuts, dp[j - 1] + 1);
                    }
                }
            }
            dp[i] = minCuts;
        }

        return dp[n - 1];
    }
};
